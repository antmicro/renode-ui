{
  "name": "renode-ui",
  "version": "1.16.0",
  "scripts": {
    "dev": "vite dev",
    "preview": "vite preview",
    "pack": "svelte-kit sync && svelte-package",
    "pack:dev": "svelte-kit sync && svelte-package -w",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "build:web": "vite build",
    "build:lib": "npm run pack",
    "test": "playwright test",
    "test:debug": "playwright test --headed --debug",
    "test:chrome": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:ci:chrome": "playwright install --with-deps > /dev/null 2>&1 && npm run test:chrome",
    "test:ci:firefox": "playwright install --with-deps firefox  > /dev/null 2>&1 && npm run test:firefox"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.49.1",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@types/node": "^24.10.1",
    "globals": "^16.5.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.7.3",
    "prettier-plugin-svelte": "^3.4.0",
    "svelte": "^5.45.3",
    "svelte-check": "^4.3.4",
    "svelte-preprocess": "^6.0.3",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vite-plugin-remove-console": "^2.2.0"
  },
  "dependencies": {
    "@lucide/svelte": "^0.542.0",
    "dockview-core": "^4.3.1",
    "renode-ws-api": "https://builds.renode.io/api/typescript+20260316gitfc1aca9b1.tgz"
  }
}
