{
    "$schema": "https://raw.githubusercontent.com/neutralinojs/neutralinojs/main/schemas/neutralino.config.schema.json",
    "applicationId": "com.antmicro.renode.ui.dbg",
    "version": "1.16.0-debug",
    "defaultMode": "window",
    "port": 0,
    "documentRoot": "/resources/",
    "url": "/",
    "enableServer": true,
    "enableNativeAPI": true,
    "tokenSecurity": "one-time",
    "logging": {
        "enabled": true,
        "writeToLogFile": false
    },
    "globalVariables": {
        "NEUTRALINO_DEBUG": true
    },
    "nativeAllowList": [
        "app.*",
        "os.*",
        "debug.log"
    ],
    "modes": {
        "window": {
            "title": "Renode UI (Debug mode)",
            "width": 800,
            "height": 500,
            "minWidth": 400,
            "minHeight": 200,
            "center": true,
            "fullScreen": false,
            "alwaysOnTop": false,
            "icon": "/resources/icon.png",
            "enableInspector": true,
            "borderless": false,
            "maximize": false,
            "hidden": false,
            "resizable": true,
            "exitProcessOnClose": true
        }
    },
    "cli": {
        "binaryName": "renode-ui-dbg",
        "resourcesPath": "/resources/",
        "extensionsPath": "/extensions/",
        "clientLibrary": "/resources/js/neutralino.js",
        "binaryVersion": "6.4.0",
        "clientVersion": "6.4.0"
    }
}